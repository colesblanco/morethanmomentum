# More Than Momentum — Cloudflare Pages Cache Rules
#
# JS, CSS, and HTML: no-cache so browsers always get the latest version after a push.
# Images and videos: long cache (1 year) since they rarely change.

/*.html
  Cache-Control: no-cache, must-revalidate

/script.js
  Cache-Control: no-cache, must-revalidate

/style.css
  Cache-Control: no-cache, must-revalidate

/functions/*
  Cache-Control: no-store

/images/*
  Cache-Control: public, max-age=31536000, immutable

/videos/*
  Cache-Control: public, max-age=31536000, immutable
